{
  "name": "Orpheus by Fulcrum (dev-$NAME)",
  "url": "https://github.com/fulcrumresearch/orpheus",
  "redirect_url": "https://github.com/fulcrumresearch/orpheus",
  "callback_urls": ["https://github.com/fulcrumresearch/orpheus"],
  "hook_attributes": {
    "url": "$BASE_URL/webhooks/github"
  },
  "public": true,
  "request_oauth_on_install": true,
  "default_permissions": {
    "contents": "write",
    "pull_requests": "write",
    "issues": "write",
    "metadata": "read"
  },
  "default_events": [
    "issue_comment",
    "pull_request",
    "pull_request_review",
    "pull_request_review_comment"
  ]
}
