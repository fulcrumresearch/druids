# Druids Server Configuration Example
# Copy this file to .env and update with your values

# Server Settings
DRUIDS_HOST=0.0.0.0
DRUIDS_PORT=8000
DRUIDS_BASE_URL=http://localhost:8000

# Database
# For SQLite (default):
# DRUIDS_DATABASE_URL=sqlite://druids.db
# For PostgreSQL:
DRUIDS_DATABASE_URL=postgresql://postgres:postgres@localhost/druids

# Sandbox Backend (docker or morphcloud)
DRUIDS_SANDBOX_TYPE=docker

# Docker Settings (when DRUIDS_SANDBOX_TYPE=docker)
DRUIDS_DOCKER_IMAGE=ghcr.io/fulcrumresearch/druids-base:latest
DRUIDS_DOCKER_HOST=localhost
# Optional: attach to existing container instead of creating new ones
# DRUIDS_DOCKER_CONTAINER_ID=

# Encryption Key (auto-generated if not set)
# DRUIDS_SECRET_KEY=your-secret-key-here

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
# DRUIDS_FORWARDING_TOKEN_SECRET=  # auto-generated if not set
# OPENAI_API_KEY=sk-...  # optional
# GITHUB_PAT=ghp_...  # optional

# Execution Limits
DRUIDS_MAX_EXECUTION_TTL=86400  # 24 hours in seconds
