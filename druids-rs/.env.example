# Druids Server Configuration
# Copy this file to .env and update with your actual values

# Server settings
DRUIDS_HOST=0.0.0.0
DRUIDS_PORT=8000
DRUIDS_BASE_URL=http://localhost:8000

# Database
# For PostgreSQL:
# DRUIDS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/druids
# For SQLite (default):
DRUIDS_DATABASE_URL=sqlite+aiosqlite:///druids.db

# Sandbox backend (docker or morphcloud)
DRUIDS_SANDBOX_TYPE=docker

# Docker settings (when DRUIDS_SANDBOX_TYPE=docker)
DRUIDS_DOCKER_IMAGE=ghcr.io/fulcrumresearch/druids-base:latest
# DRUIDS_DOCKER_CONTAINER_ID=  # Optional: attach to existing container
DRUIDS_DOCKER_HOST=localhost

# Security
# Auto-generated if not set - save this value after first run!
# DRUIDS_SECRET_KEY=
# FORWARDING_TOKEN_SECRET=

# API Keys (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional API Keys
# OPENAI_API_KEY=
# GITHUB_PAT=

# Execution limits
DRUIDS_MAX_EXECUTION_TTL=86400  # 24 hours in seconds
