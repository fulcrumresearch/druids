# Copy this to server/.env and fill in your values.

# Required
ANTHROPIC_API_KEY=sk-ant-xxx

# Required for git operations (agents clone repos and push branches with this)
GITHUB_PAT=ghp_xxx

# Auto-generated if not set. Uncomment to pin a stable value:
# DRUIDS_SECRET_KEY=<fernet-key>
# FORWARDING_TOKEN_SECRET=<random-string>

# The URL agents use to reach the server from inside Docker containers.
# Default: http://localhost:8000 (only works if agents run on the host).
# Linux Docker: http://172.17.0.1:8000
# macOS Docker Desktop: http://host.docker.internal:8000
# Docker Compose sets this automatically.
DRUIDS_BASE_URL=http://172.17.0.1:8000

# Optional: for Codex agents
# OPENAI_API_KEY=sk-proj-xxx

# Optional: restrict login to specific GitHub users (comma-separated)
# GITHUB_ALLOWED_USERS=yourhandle,teammate
